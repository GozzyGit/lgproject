"triggers": {
  "Recurrence": {
    "type": "Recurrence",
    "recurrence": {
      "frequency": "Day",
      "interval": 1,
      "schedule": {
        "hours": [8],
        "minutes": [0]
      }
    }
  }
}



"Get_Costs": {
  "type": "Http",
  "inputs": {
    "method": "POST",
    "uri": "https://management.azure.com/subscriptions/YOUR_SUBSCRIPTION_ID/providers/Microsoft.CostManagement/query?api-version=2023-03-01",
    "headers": {
      "Content-Type": "application/json"
    },
    "authentication": {
      "type": "ManagedServiceIdentity",
      "audience": "https://management.azure.com/"
    },
    "body": {
      "type": "ActualCost",
      "timeframe": "BillingMonthToDate",
      "dataset": {
        "granularity": "None",
        "aggregation": {
          "totalCost": {
            "name": "PreTaxCost",
            "function": "Sum"
          }
        }
      }
    }
  }
}



"Get_Costs": {
  "type": "Http",
  "inputs": {
    "method": "POST",
    "uri": "https://management.azure.com/subscriptions/YOUR_SUBSCRIPTION_ID/providers/Microsoft.CostManagement/query?api-version=2023-03-01",
    "headers": {
      "Content-Type": "application/json"
    },
    "authentication": {
      "type": "ManagedServiceIdentity",
      "audience": "https://management.azure.com/"
    },
    "body": {
      "type": "ActualCost",
      "timeframe": "BillingMonthToDate",
      "dataset": {
        "granularity": "None",
        "aggregation": {
          "totalCost": {
            "name": "PreTaxCost",
            "function": "Sum"
          }
        }
      }
    }
  }
}




"Send_Email": {
  "type": "ApiConnection",
  "inputs": {
    "method": "post",
    "path": "/v2/Mail",
    "body": {
      "To": "lee.gosling876@outlook.com",
      "Subject": "Azure Cost Report (Daily FinOps)",
      "Body": "@{body('Get_Costs')}",
      "Importance": "Normal"
    }
  }
}