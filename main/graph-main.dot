digraph G {
  rankdir = "RL";
  node [shape = rect, fontname = "sans-serif"];
  "random_id.suffix" [label="random_id.suffix"];
  subgraph "cluster_module.cost_function" {
    label = "module.cost_function"
    fontname = "sans-serif"
    "module.cost_function.azurerm_linux_function_app.func" [label="azurerm_linux_function_app.func"];
    "module.cost_function.azurerm_service_plan.plan" [label="azurerm_service_plan.plan"];
  }
  subgraph "cluster_module.key_vault" {
    label = "module.key_vault"
    fontname = "sans-serif"
    "module.key_vault.data.azurerm_client_config.current" [label="data.azurerm_client_config.current"];
    "module.key_vault.azurerm_key_vault.kv" [label="azurerm_key_vault.kv"];
  }
  subgraph "cluster_module.resource_group" {
    label = "module.resource_group"
    fontname = "sans-serif"
    "module.resource_group.azurerm_resource_group.rg" [label="azurerm_resource_group.rg"];
  }
  subgraph "cluster_module.storage" {
    label = "module.storage"
    fontname = "sans-serif"
    "module.storage.azurerm_storage_account.sa" [label="azurerm_storage_account.sa"];
    "module.storage.azurerm_storage_container.logs" [label="azurerm_storage_container.logs"];
    "module.storage.azurerm_storage_container.sqldata" [label="azurerm_storage_container.sqldata"];
    "module.storage.azurerm_storage_container.webdata" [label="azurerm_storage_container.webdata"];
  }
  "module.cost_function.azurerm_linux_function_app.func" -> "module.cost_function.azurerm_service_plan.plan";
  "module.cost_function.azurerm_linux_function_app.func" -> "module.storage.azurerm_storage_account.sa";
  "module.cost_function.azurerm_service_plan.plan" -> "module.resource_group.azurerm_resource_group.rg";
  "module.key_vault.azurerm_key_vault.kv" -> "module.key_vault.data.azurerm_client_config.current";
  "module.key_vault.azurerm_key_vault.kv" -> "module.resource_group.azurerm_resource_group.rg";
  "module.resource_group.azurerm_resource_group.rg" -> "random_id.suffix";
  "module.storage.azurerm_storage_account.sa" -> "module.resource_group.azurerm_resource_group.rg";
  "module.storage.azurerm_storage_container.logs" -> "module.storage.azurerm_storage_account.sa";
  "module.storage.azurerm_storage_container.sqldata" -> "module.storage.azurerm_storage_account.sa";
  "module.storage.azurerm_storage_container.webdata" -> "module.storage.azurerm_storage_account.sa";
}
